# K-Semi Signal — production environment template.
# Copy to .env.local and fill in. The app builds and runs with NONE of these set
# (mock generation, console-logged email, file-backed storage); each one you add
# upgrades the corresponding layer to its real implementation.
#
# NEVER put real secrets in this file — it is committed. Real values go in
# .env.local (gitignored).

# --- AI (server-only) — report generation via Claude ---
# Without this, the generator returns rule-based mock reports.
ANTHROPIC_API_KEY=sk-ant-...
# Default claude-opus-4-8. Use claude-sonnet-4-6 for ~1/3 cost, claude-haiku-4-5 cheapest.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Email (server-only) — Resend ---
# Without this, sends are logged and deliveries marked "skipped".
RESEND_API_KEY=re_...
RESEND_FROM="K-Semi Signal <brief@your-domain.com>"

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Protects /api/reports/* and the admin workflow.
ADMIN_SECRET=change-me
# Protects /api/cron/*.
CRON_SECRET=change-me

# --- Database (server-only) ---
# Without this, persistence uses a local file store under .data/.
DATABASE_URL=postgresql://user:pass@host:5432/k_semi

# --- Market data (server-only) — Korea Investment & Securities OpenAPI ---
# Without these, the terminal serves mock KOSPI/index values (marked not-live).
# Reuse the same app key/secret as any other KIS integration.
KIS_APP_KEY=
KIS_APP_SECRET=
# "real" (default, live market) or "paper" (모의투자 host).
KIS_ENV=real

# --- Observability (optional) ---
SENTRY_DSN=
